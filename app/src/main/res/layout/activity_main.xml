<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Node"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintCenterX="Parent"
            android:layout_marginTop="16dp"/>

        <!-- 状态文本 -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="状态: 未连接"
            android:textSize="16sp"
            android:textColor="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintCenterX="Parent"
            android:layout_marginTop="8dp"/>

        <!-- 语音状态 -->
        <TextView
            android:id="@+id/voiceStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="语音: 空闲"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/statusText"
            app:layout_constraintCenterX="Parent"
            android:layout_marginTop="4dp"/>

        <!-- 分隔线 -->
        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/voiceStatusText"
            android:layout_marginTop="16dp"/>

        <!-- Gateway URL 输入 -->
        <TextView
            android:id="@+id/gatewayUrlLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gateway URL"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider1"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/gatewayUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ws://192.168.1.100:18789"
            android:inputType="textUri"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/gatewayUrlLabel"
            android:layout_marginTop="8dp"/>

        <!-- 设备 Token 输入 -->
        <TextView
            android:id="@+id/deviceTokenLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设备 Token (可选)"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/gatewayUrlInput"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp"/>

        <EditText
            android:id="@+id/deviceTokenInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="留空跳过认证"
            android:inputType="textPassword"
            android:singleLine="true"
            app:layout_constraintTop_toBottomOf="@id/deviceTokenLabel"
            android:layout_marginTop="8dp"/>

        <!-- 连接按钮 -->
        <Button
            android:id="@+id/connectButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="连接"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/deviceTokenInput"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/disconnectButton"
            android:layout_marginTop="24dp"/>

        <!-- 断开按钮 -->
        <Button
            android:id="@+id/disconnectButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="断开"
            android:enabled="false"
            app:layout_constraintTop_toBottomOf="@id/deviceTokenInput"
            app:layout_constraintStart_toEndOf="@id/connectButton"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp"/>

        <!-- 启动服务按钮 -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="启动服务"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toBottomOf="@id/connectButton"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/stopButton"
            android:layout_marginTop="16dp"/>

        <!-- 停止服务按钮 -->
        <Button
            android:id="@+id/stopButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="停止服务"
            android:enabled="false"
            app:layout_constraintTop_toBottomOf="@id/connectButton"
            app:layout_constraintStart_toEndOf="@id/startButton"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- 分隔线 -->
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/startButton"
            android:layout_marginTop="24dp"/>

        <!-- 日志输出 -->
        <TextView
            android:id="@+id/logLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="日志"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/logText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="200dp"
            android:text="日志:\n"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@android:color/darker_gray"
            android:textColor="@android:color/white"
            android:padding="8dp"
            android:scrollbars="vertical"
            app:layout_constraintTop_toBottomOf="@id/logLabel"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>